{
  "name": "skippy-mcp-and-app",
  "version": "0.0.0",
  "private": true,
  "description": "Skippy MCP server and PWA app backed by Convex.",
  "packageManager": "pnpm@8.10.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r --sort build",
    "test": "pnpm --filter @skippy/shared build && pnpm -r --sort test",
    "typecheck": "pnpm --filter @skippy/shared build && pnpm --filter @skippy/mcp-server build && pnpm -r --sort typecheck && pnpm convex:typecheck",
    "convex:typecheck": "tsc -p convex/tsconfig.json --noEmit",
    "mcp:smoke": "pnpm --filter @skippy/mcp-server smoke:remote",
    "lint": "pnpm -r lint",
    "check": "pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "eslint": "^10.4.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "dependencies": {
    "@skippy/shared": "workspace:*",
    "convex": "^1.40.0"
  }
}
